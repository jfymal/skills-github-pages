    </div>

    <div class="form-group">
      <label for="num-preguntas">Número de preguntas:</label>
      <input type="number" id="num-preguntas" min="1" value="10">
    </div>

    <button id="btn-empezar" class="btn-success">Empezar Quiz</button>
  </div>

  <div id="quiz-container" class="hidden"></div>





