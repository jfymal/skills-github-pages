    // Elementos del DOM
    const configContainer = document.getElementById('config-container');
    const selectAsignatura = document.getElementById('asignatura');
    const numPreguntasInput = document.getElementById('num-preguntas');
    const btnEmpezar = document.getElementById('btn-empezar');
    const quizContainer = document.getElementById('quiz-container');

    // Variables de estado
    let estado = {
      asignatura: '',
      numPreguntas: 10,
      preguntasDisponibles: [],
      preguntasMostradas: [],
      preguntasIncorrectas: [],
      indicePregunta: 0,
      respuestasCorrectas: 0,
      respuestasIncorrectas: 0,
      timer: null,
      modoRepeticion: false
    };

    // Event Listeners
    btnEmpezar.addEventListener('click', iniciarQuiz);
    selectAsignatura.addEventListener('change', actualizarEstado);
    numPreguntasInput.addEventListener('change', actualizarEstado);

    // Funciones principales
    function actualizarEstado() {
      estado.asignatura = selectAsignatura.value;
      estado.numPreguntas = parseInt(numPreguntasInput.value) || 10;
    }

    function iniciarQuiz() {
      actualizarEstado();

      if (!estado.asignatura) {
        alert('Por favor selecciona una asignatura');
        return;
      }

      // Obtener preguntas para la asignatura seleccionada
      estado.preguntasDisponibles = [...(preguntasPorAsignatura[estado.asignatura] || [])];

      if (estado.preguntasDisponibles.length === 0) {
        alert(`No hay preguntas disponibles para la asignatura de ${estado.asignatura}`);
        return;
      }

      // Validar número de preguntas
      if (estado.numPreguntas > estado.preguntasDisponibles.length) {
        alert(`Solo hay ${estado.preguntasDisponibles.length} preguntas disponibles para esta asignatura. Se ajustará el número.`);
        estado.numPreguntas = estado.preguntasDisponibles.length;
        numPreguntasInput.value = estado.preguntasDisponibles.length;
      }

      // Mezclar preguntas
      shuffleArray(estado.preguntasDisponibles);

      // Seleccionar las primeras N preguntas
      estado.preguntasMostradas = estado.preguntasDisponibles.slice(0, estado.numPreguntas);

      // Reiniciar contadores
      estado.indicePregunta = 0;
      estado.respuestasCorrectas = 0;
      estado.respuestasIncorrectas = 0;
      estado.preguntasIncorrectas = [];
      estado.modoRepeticion = false;

      // Mostrar el quiz
      configContainer.classList.add('hidden');
      quizContainer.classList.remove('hidden');

      mostrarPregunta();
    }

    function mostrarPregunta() {
      if (estado.timer) clearTimeout(estado.timer);

      const pregunta = estado.preguntasMostradas[estado.indicePregunta];
      const progreso = ((estado.indicePregunta) / estado.preguntasMostradas.length) * 100;

      // Generar HTML de las opciones de respuesta
      let opcionesHTML = pregunta.opciones.map((op, idx) => `
        <div class="opcion">
          <input type="radio" id="op${idx}" name="respuesta" value="${op}">
          <label for="op${idx}">${op}</label>
        </div>
      `).join('');

      // Construir el HTML completo de la pregunta
      quizContainer.innerHTML = `
        <div class="progress-container">
          <div class="progress-bar">
            <div class="progress" style="width: ${progreso}%"></div>
          </div>
          <div class="progress-text">${estado.indicePregunta}/${estado.preguntasMostradas.length}</div>
        </div>
        <div class="question-counter">Asignatura: ${estado.asignatura} | Modo: ${estado.modoRepeticion ? 'Repetición' : 'Normal'}</div>
        <h3>Pregunta ${estado.indicePregunta + 1}</h3>
        <p>${pregunta.pregunta}</p>
        <form id="form-pregunta">
          ${opcionesHTML}
        </form>
        <div id="feedback" class="hidden"></div>
        <button id="btn-siguiente-pregunta" class="btn-secondary hidden" style="margin-top: 1rem;">Siguiente pregunta</button>
      `;

      // Añadir eventos a las opciones para selección por click en el div
      const opcionesDiv = document.querySelectorAll('.opcion');
      opcionesDiv.forEach(opcionDiv => {
        opcionDiv.addEventListener('click', function() {
          const radio = this.querySelector('input[type="radio"]');
          radio.checked = true;
          validarRespuesta(radio.value); // Llama a validarRespuesta directamente
        });
      });

      // Evento para el nuevo botón "Siguiente pregunta"
      document.getElementById('btn-siguiente-pregunta').addEventListener('click', siguientePregunta);
    }

    // Modificada para recibir la respuesta directamente
    function validarRespuesta(respuestaSeleccionada) {
      const pregunta = estado.preguntasMostradas[estado.indicePregunta];
      const feedback = document.getElementById('feedback');
      const nextButton = document.getElementById('btn-siguiente-pregunta');
      const opciones = document.querySelectorAll('input[type="radio"]');

      // Deshabilitar todas las opciones de radio una vez que se selecciona una
      opciones.forEach(op => op.disabled = true);

      // Mostrar feedback
      feedback.classList.remove('hidden');

      if (respuestaSeleccionada === pregunta.respuesta_correcta) {
        feedback.textContent = '¡Respuesta correcta! 🎉';
        feedback.className = 'feedback-correct';
        estado.respuestasCorrectas++;
        // Si es correcta, avanza automáticamente tras 2 segundos
        estado.timer = setTimeout(() => {
          estado.indicePregunta++;
          if (estado.indicePregunta < estado.preguntasMostradas.length) {
            mostrarPregunta();
          } else {
            mostrarResultados();
          }
        }, 2000);
      } else {
        feedback.textContent = `Respuesta incorrecta. La correcta es: "${pregunta.respuesta_correcta}". Explicación: ${pregunta.explicacion}`;
        feedback.className = 'feedback-incorrect';
        estado.respuestasIncorrectas++;
        // Guardar pregunta incorrecta para posible repetición
        estado.preguntasIncorrectas.push(pregunta);
        // Mostrar el botón "Siguiente pregunta"
        nextButton.classList.remove('hidden');
        // Limpiar cualquier temporizador pendiente si el usuario responde incorrectamente
        if (estado.timer) clearTimeout(estado.timer);
      }
    }

    function siguientePregunta() {
      // Avanzar a la siguiente pregunta
      estado.indicePregunta++;
      if (estado.indicePregunta < estado.preguntasMostradas.length) {
        mostrarPregunta();
      } else {
        mostrarResultados();
      }
    }

    function mostrarResultados() {
      const porcentaje = Math.round((estado.respuestasCorrectas / estado.preguntasMostradas.length) * 100);
      let mensajeFinal = '';

      if (porcentaje >= 90) {
        mensajeFinal = '¡Excelente! Dominas este tema 🏆';
      } else if (porcentaje >= 70) {
        mensajeFinal = '¡Buen trabajo! 👍';
      } else if (porcentaje >= 50) {
        mensajeFinal = 'No está mal, pero puedes mejorar 💪';
      } else {
        mensajeFinal = 'Sigue practicando para mejorar tus resultados 📚';
      }

      quizContainer.innerHTML = `
        <div class="results">
          <h2>${mensajeFinal}</h2>
          <p>Asignatura: <strong>${estado.asignatura}</strong></p>
          <p>Preguntas totales: <strong>${estado.preguntasMostradas.length}</strong></p>
          <p>Respuestas correctas: <strong style="color: var(--success-color)">${estado.respuestasCorrectas}</strong></p>
          <p>Respuestas incorrectas: <strong style="color: var(--error-color)">${estado.respuestasIncorrectas}</strong></p>
          <p>Porcentaje de acierto: <strong>${porcentaje}%</strong></p>

          <div class="action-buttons">
            ${estado.preguntasIncorrectas.length > 0 ?
              `<button id="btn-repetir-incorrectas" class="btn-error">Repetir incorrectas (${estado.preguntasIncorrectas.length})</button>` : ''}
            <button id="btn-nuevo-quiz" class="btn-secondary">Nuevo quiz</button>
            <button id="btn-continuar" class="btn-success">Continuar con nuevas preguntas</button>
          </div>
        </div>
      `;

      // Configurar eventos de los botones de acción
      if (estado.preguntasIncorrectas.length > 0) {
        document.getElementById('btn-repetir-incorrectas').addEventListener('click', repetirIncorrectas);
      }
      document.getElementById('btn-nuevo-quiz').addEventListener('click', reiniciarQuiz);
      document.getElementById('btn-continuar').addEventListener('click', continuarQuiz);
    }

    function repetirIncorrectas() {
      // Filtrar preguntas disponibles para eliminar las ya mostradas
      estado.preguntasDisponibles = estado.preguntasDisponibles.filter(p =>
        !estado.preguntasMostradas.some(mostrada => mostrada.id === p.id)
      );

      // Configurar el modo repetición
      estado.preguntasMostradas = [...estado.preguntasIncorrectas];
      estado.indicePregunta = 0;
      estado.respuestasCorrectas = 0;
      estado.respuestasIncorrectas = 0;
      estado.preguntasIncorrectas = [];
      estado.modoRepeticion = true;

      mostrarPregunta();
    }

    function reiniciarQuiz() {
      // Volver a la configuración inicial
      quizContainer.classList.add('hidden');
      configContainer.classList.remove('hidden');
    }

    function continuarQuiz() {
      // Filtrar preguntas disponibles para eliminar las ya mostradas
      estado.preguntasDisponibles = estado.preguntasDisponibles.filter(p =>
        !estado.preguntasMostradas.some(mostrada => mostrada.id === p.id)
      );

      if (estado.preguntasDisponibles.length === 0) {
        alert('No hay más preguntas disponibles para esta asignatura');
        reiniciarQuiz();
        return;
      }

      // Determinar cuántas preguntas nuevas mostrar
      const preguntasRestantes = estado.preguntasDisponibles.length;
      const numPreguntas = Math.min(estado.numPreguntas, preguntasRestantes);

      // Mezclar y seleccionar nuevas preguntas
      shuffleArray(estado.preguntasDisponibles);
      estado.preguntasMostradas = estado.preguntasDisponibles.slice(0, numPreguntas);

      // Reiniciar contadores
      estado.indicePregunta = 0;
      estado.respuestasCorrectas = 0;
      estado.respuestasIncorrectas = 0;
      estado.preguntasIncorrectas = [];
      estado.modoRepeticion = false;

      mostrarPregunta();
    }

    // Función auxiliar para mezclar array (Fisher-Yates shuffle)
    function shuffleArray(array) {
      for (let i = array.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
      }
      return array;
    }

