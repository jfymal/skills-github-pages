<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cuestionario Exámenes Junio</title>
  <style>
    :root {
      --primary-color: #3498db;
      --secondary-color: #2980b9;
      --success-color: #27ae60;
      --error-color: #e74c3c;
      --light-gray: #ecf0f1;
      --dark-gray: #7f8c8d;
      --text-color: #2c3e50;
    }

    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      max-width: 800px;
      margin: 2rem auto;
      padding: 0 1rem;
      line-height: 1.6;
      color: var(--text-color);
      background-color: #f5f7fa;
    }

    h1 {
      color: var(--text-color);
      text-align: center;
      margin-bottom: 1.5rem;
      font-size: 2rem;
    }

    .config-container {
      background: white;
      padding: 1.5rem;
      border-radius: 10px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.08);
      margin-bottom: 1.5rem;
    }

    .form-group {
      margin-bottom: 1.2rem;
    }

    label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }

    select, input, button {
      padding: 0.7rem;
      border-radius: 6px;
      border: 1px solid #ddd;
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    select, input {
      width: 100%;
      max-width: 350px;
      background-color: white;
    }

    select:focus, input:focus {
      outline: none;
      border-color: var(--primary-color);
      box-shadow: 0 0 0 2px rgba(52, 152, 219, 0.2);
    }

    input[type="number"] {
      width: 80px;
    }

    button {
      background-color: var(--primary-color);
      color: white;
      border: none;
      padding: 0.8rem 1.5rem;
      cursor: pointer;
      transition: all 0.3s;
      font-weight: bold;
      margin-right: 0.8rem;
      margin-bottom: 0.8rem;
    }

    button:hover {
      background-color: var(--secondary-color);
      transform: translateY(-2px);
    }

    button:disabled {
      background-color: var(--dark-gray);
      cursor: not-allowed;
      transform: none;
    }

    .btn-success {
      background-color: var(--success-color);
    }

    .btn-success:hover {
      background-color: #219653;
    }

    .btn-error {
      background-color: var(--error-color);
    }

    .btn-error:hover {
      background-color: #c0392b;
    }

    .btn-secondary {
      background-color: var(--dark-gray);
    }

    .btn-secondary:hover {
      background-color: #6c7a7d;
    }

    .opcion {
      margin: 0.7rem 0;
      padding: 0.8rem;
      background: #fff;
      border-radius: 6px;
      border: 1px solid #eee;
      cursor: pointer;
      transition: all 0.2s;
      display: flex; /* Para alinear el texto de la opción */
      align-items: center; /* Para centrar verticalmente el texto */
    }

    .opcion:hover {
      background: #f0f7fc;
      border-color: #d6eaf8;
    }

    /* Ocultar el radio button nativo */
    .opcion input[type="radio"] {
      display: none; /* Oculta el círculo del radio button */
    }

    /* Estilo para la etiqueta de la opción cuando no está seleccionada */
    .opcion label {
      cursor: pointer;
      flex-grow: 1; /* Permite que la etiqueta ocupe el espacio restante */
      padding-left: 0.5rem; /* Espacio a la izquierda del texto */
    }

    /* Estilo para la opción seleccionada */
    .opcion input[type="radio"]:checked + label {
      font-weight: bold;
      color: var(--primary-color);
    }

    #quiz-container {
      margin-top: 1rem;
      padding: 1.5rem;
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

    .feedback-correct {
      color: var(--success-color);
      font-weight: bold;
      padding: 1rem;
      background: #e8f5e9;
      border-radius: 6px;
      margin-top: 1rem;
      animation: fadeIn 0.5s;
    }

    .feedback-incorrect {
      color: var(--error-color);
      padding: 1rem;
      background: #ffebee;
      border-radius: 6px;
      margin-top: 1rem;
      animation: fadeIn 0.5s;
    }

    .progress-container {
      display: flex;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .progress-bar {
      height: 8px;
      background: var(--light-gray);
      border-radius: 10px;
      overflow: hidden;
      flex-grow: 1;
      margin-right: 1rem;
    }

    .progress {
      height: 100%;
      background: linear-gradient(90deg, var(--primary-color), var(--success-color));
      width: 0%;
      transition: width 0.5s ease;
    }

    .progress-text {
      font-weight: bold;
      min-width: 80px;
      text-align: right;
    }

    .hidden {
      display: none;
    }

    .results {
      text-align: center;
      padding: 1.5rem;
    }

    .results h2 {
      color: var(--text-color);
      margin-bottom: 1.5rem;
    }

    .results p {
      margin: 0.8rem 0;
      font-size: 1.1rem;
    }

    .action-buttons {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 2rem;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    .question-counter {
      font-size: 0.9rem;
      color: var(--dark-gray);
      margin-bottom: 0.5rem;
    }
  </style>
</head>
<body>
  <h1>Simulacros examen Junio</h1>

  <div id="puntuacion" style="font-size:1.5em; margin-bottom:1em;">Puntuación: 0</div>

  <div id="config-container" class="config-container">
    <div class="form-group">
      <label for="asignatura">Asignatura:</label>
